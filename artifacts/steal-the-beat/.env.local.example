# ============================================================
# Steal the Beat by Blayke — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Your WordPress/WooCommerce site URL (no trailing slash)
NEXT_PUBLIC_WORDPRESS_URL=https://your-woocommerce-store.com

# WooCommerce REST API Keys
# Generate at: WooCommerce > Settings > Advanced > REST API
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
